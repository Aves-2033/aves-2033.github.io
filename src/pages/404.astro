---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Страница не найдена | Прокат от Кет"
  description="Запрашиваемая страница не найдена. Вернитесь на главную или откройте каталог платьев."
  canonicalUrl="https://ketrent.ru/404"
>
  <section class="hero" style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
    <div class="hero-overlay"></div>
    <div class="container hero-container" style="text-align: center;">
      <h1 class="hero-title" style="font-size: 6rem; margin-bottom: 0.5rem;">404</h1>
      <p class="hero-subtitle" style="font-size: 1.5rem; margin-bottom: 2rem;">
        Страница не найдена
      </p>
      <p class="hero-subtitle" style="font-size: 1.1rem; opacity: 0.8; margin-bottom: 2rem;">
        Возможно, эта страница была перемещена или удалена.
      </p>
      <div class="hero-actions" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn-hero">На главную</a>
        <a href="/catalog" class="btn btn-outline" style="color: #fff; border-color: rgba(255,255,255,0.5);">Каталог</a>
      </div>
    </div>
  </section>
</BaseLayout>
